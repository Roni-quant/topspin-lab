# ITTF results portal credentials (for the scraper)
# Option A: Auto-login (recommended)
# Pipeline will log in automatically and manage session cookies.
ITTF_USERNAME=your_username
ITTF_PASSWORD=your_password

# Option B: Manual cookie (fallback)
# Paste the full Cookie header from browser dev tools.
# In browser: Dev Tools -> Network tab -> click any request to results.ittf.link -> Headers -> Cookie
# ITTF_COOKIE_HEADER=joomla_session=abc123; other_cookie=xyz789
